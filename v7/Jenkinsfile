// Pipeline complet : Build + Push Docker Hub + Deploiement
pipeline {
    agent any

    environment {
        COMPOSE_FILE   = 'docker-compose.yml'
        DOCKERHUB_USER = 'siakhakaba19'
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Preparation env') {
            steps {
                bat 'copy "C:\\secrets\\backend.env" "%WORKSPACE%\\v7\\backend\\.env"'
            }
        }

        stage('Build') {
            steps {
                echo "Construction des images Docker..."
                bat "cd v7 && docker compose -f %COMPOSE_FILE% build --no-cache"
            }
        }

        stage('Tag images') {
            steps {
                echo "Tag des images pour Docker Hub..."
                bat """
                    docker tag v7-backend %DOCKERHUB_USER%/portfolio-backend:%IMAGE_TAG%
                    docker tag v7-backend %DOCKERHUB_USER%/portfolio-backend:latest
                    docker tag v7-frontend %DOCKERHUB_USER%/portfolio-frontend:%IMAGE_TAG%
                    docker tag v7-frontend %DOCKERHUB_USER%/portfolio-frontend:latest
                """
            }
        }

        stage('Push Docker Hub') {
            steps {
                echo "Connexion et push vers Docker Hub..."
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat """
                        echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin
                        docker push %DOCKERHUB_USER%/portfolio-backend:%IMAGE_TAG%
                        docker push %DOCKERHUB_USER%/portfolio-backend:latest
                        docker push %DOCKERHUB_USER%/portfolio-frontend:%IMAGE_TAG%
                        docker push %DOCKERHUB_USER%/portfolio-frontend:latest
                        docker logout
                    """
                }
            }
        }

        stage('Arret') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% down --remove-orphans || exit 0"
            }
        }

        stage('Deploiement') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% up -d"
                sleep(time: 15, unit: 'SECONDS')
            }
        }

        stage('Verification') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% ps"
                bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=30 frontend"
                bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=30 backend"
            }
        }

    }

    post {

        success {
            echo "Pipeline reussi - Portfolio deploye et images publiees sur Docker Hub"
            emailext(
                subject: "SUCCESS - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """<h2 style="color:green;">Deploiement reussi</h2>
                <p><b>Projet :</b> ${env.JOB_NAME}</p>
                <p><b>Build :</b> ${env.BUILD_NUMBER}</p>
                <p><b>Statut :</b> SUCCESS</p>
                <p><b>Lien Jenkins :</b> <a href='${env.BUILD_URL}'>${env.BUILD_URL}</a></p>
                <p><b>Application :</b> <a href='http://localhost:8080'>http://localhost:8080</a></p>
                <hr>
                <h3>Images publiees sur Docker Hub :</h3>
                <ul>
                    <li><a href='https://hub.docker.com/r/siakhakaba19/portfolio-backend'>siakhakaba19/portfolio-backend:${env.BUILD_NUMBER}</a></li>
                    <li><a href='https://hub.docker.com/r/siakhakaba19/portfolio-frontend'>siakhakaba19/portfolio-frontend:${env.BUILD_NUMBER}</a></li>
                </ul>""",
                mimeType: 'text/html',
                to: 'siakha.kaba94@gmail.com',
                from: 'siakha.kaba94@gmail.com',
                replyTo: 'siakha.kaba94@gmail.com'
            )
        }

        failure {
            echo "Pipeline echoue - consulte les logs"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=100 || exit 0"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% down || exit 0"
            bat "docker logout || exit 0"
            emailext(
                subject: "FAILURE - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """<h2 style="color:red;">Deploiement echoue</h2>
                <p><b>Projet :</b> ${env.JOB_NAME}</p>
                <p><b>Build :</b> ${env.BUILD_NUMBER}</p>
                <p><b>Statut :</b> FAILURE</p>
                <p><b>Logs :</b> <a href='${env.BUILD_URL}console'>${env.BUILD_URL}console</a></p>
                <p>Une erreur est survenue pendant le pipeline. Consulte les logs Jenkins pour plus de details.</p>""",
                mimeType: 'text/html',
                to: 'siakha.kaba94@gmail.com',
                from: 'siakha.kaba94@gmail.com',
                replyTo: 'siakha.kaba94@gmail.com'
            )
        }

        always {
            echo "Verification finale"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% ps || exit 0"
        }

    }
}